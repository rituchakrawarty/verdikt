# Copy this file to ".env" and paste your real keys. The .env file is gitignored.
#   cp .env.example .env   then edit .env

# Required for the Claude reasoning engine (starts with sk-ant-, ~100 chars, no "...").
ANTHROPIC_API_KEY=

# Optional — raise rate limits (both sources work without a key).
NCBI_API_KEY=
OPENFDA_API_KEY=

# Optional overrides.
# VERDIKT_MODEL=claude-opus-4-8

# Public-demo cost guard — leave OFF for local use; the Render deploy turns it on.
# Bounds token spend on a shared URL without restricting what visitors can search.
# VERDIKT_DEMO=1
# VERDIKT_DAILY_CAP=150       # max investigations/day across all visitors
# VERDIKT_IP_HOURLY_CAP=6     # max investigations/hour per IP
